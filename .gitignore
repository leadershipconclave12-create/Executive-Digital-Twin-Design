# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Compiled Go binaries
*.exe

# Secrets — never commit. Use .env.example as the template.
.env
.env.*
!.env.example
*.key
*.pem

# Runtime data — event logs & snapshots are the org's history, not source.
# Anchored to the ACTUAL runtime dirs so this never swallows SOURCE directories
# named "data" (server/src/data, eios-go/internal/data) — the bug that shipped
# the prototype un-buildable.
/data/
/eios-prototype/data/
/eios-prototype/server/data/
/eios-go/data/
*.jsonl
snapshot.json

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
