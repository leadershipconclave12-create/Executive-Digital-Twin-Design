# ═══════════════════════════════════════════════════════════════════════
#  EIOS configuration.  Copy to `.env` and fill in.       cp .env.example .env
#  `.env` is gitignored. Never commit real keys.
# ═══════════════════════════════════════════════════════════════════════

# ── REASONING (required for real triage/reasoning) ─────────────────────
# Any OpenAI-compatible endpoint. Pick ONE:
#
#  Your internal company gateway (most likely — ask for the base URL + key):
EIOS_LLM_BASE_URL=https://your-internal-ai-gateway/v1
EIOS_LLM_API_KEY=your-key-here
#
#  Azure OpenAI:
#    EIOS_LLM_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#    EIOS_LLM_API_KEY=<azure key>
#
#  Free / offline (Ollama on your laptop — no network, no cost, weaker results):
#    EIOS_LLM_BASE_URL=http://localhost:11434/v1
#    EIOS_LLM_API_KEY=ollama
#    EIOS_LLM_SMALL_MODEL=phi3:mini
#    EIOS_LLM_FRONTIER_MODEL=llama3.1:8b

# ── MODEL ROUTING — this is what makes $50 last a year ─────────────────
# Small model does the 300 triage calls/day (~$0.05/day).
# Frontier model is spent ONLY on the ~3 things that reach you.
EIOS_LLM_SMALL_MODEL=gpt-4o-mini
EIOS_LLM_FRONTIER_MODEL=gpt-4o

# ── BUDGET — hard stop. EIOS refuses to call once this is spent. ───────
EIOS_LLM_BUDGET_USD=50

# If your gateway bills differently, override (USD per 1M tokens):
# EIOS_LLM_PRICING={"my-model":{"inputPer1M":0.5,"outputPer1M":1.5}}
# If it needs a custom auth header:
# EIOS_LLM_HEADERS={"x-api-key":"...","x-team":"..."}

# ── GOVERNANCE ─────────────────────────────────────────────────────────
# ADR-003: no autonomous action may commit money at/above this. In paise-free INR.
EIOS_AUTONOMOUS_LIMIT_INR=1000000
EIOS_AUTO_CONFIDENCE=0.85

# ── PLATFORM ───────────────────────────────────────────────────────────
PORT=4180
EIOS_EVENT_LOG=./data/events.jsonl   # set to `off` for an ephemeral run
EIOS_SNAPSHOT=./data/snapshot.json
